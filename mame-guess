#!/usr/bin/env python3
"""
mame_core_picker.py
Recommends the correct MAME libretro core for a given ROM zip file
by matching its contents against DAT/XML files.

Usage:
    python3 mame_core_picker.py <rom.zip> <dat_folder>

Example:
    python3 mame_core_picker.py dino.zip ~/dats/
"""

import sys
import os
import json
import zipfile
import xml.etree.ElementTree as ET

# ── Core definitions ──────────────────────────────────────────────────────────
# Order matters: checked from most specific/oldest to newest.
# mame_libretro.so is the fallback (last).
CORES = [
    {
        "core":    "mame2000_libretro.so",
        "dat":     "mame2000.xml",
        "label":   "MAME 2000 (0.37b5)",
    },
    {
        "core":    "mame2003_libretro.so",
        "dat":     "mame2003.xml",
        "label":   "MAME 2003 (0.78)",
    },
    {
        "core":    "mame2003_plus_libretro.so",
        "dat":     "mame2003-plus.xml",
        "label":   "MAME 2003-Plus (0.78+)",
    },
    {
        "core":    "mame2010_libretro.so",
        "dat":     "mame2010.xml",
        "label":   "MAME 2010 (0.139)",
    },
    {
        "core":    "mame_libretro.so",
        "dat":     "mame.xml",
        "label":   "MAME Current (latest)",
    },
]

DEFAULT_CORE = "mame_libretro.so"


def die(msg):
    print(f"ERROR: {msg}", file=sys.stderr)
    sys.exit(1)


def get_rom_name(zip_path):
    """
    Returns the ROM set name (zip filename without extension, lowercased).
    """

    return os.path.splitext(os.path.basename(zip_path))[0].lower()


def get_zip_filenames(zip_path):
    """
    Returns a set of filenames contained inside the zip.
    """

    with zipfile.ZipFile(zip_path, "r") as zf:
        return {info.filename.lower() for info in zf.infolist()}


def get_cache_dir():
    """
    Returns the cache directory used for DAT indexes.
    """

    cache_home = os.environ.get("XDG_CACHE_HOME")
    if not cache_home:
        cache_home = os.path.join(os.path.expanduser("~"), ".cache")
    cache_dir = os.path.join(cache_home, "mame-guess")
    os.makedirs(cache_dir, exist_ok=True)
    return cache_dir


def get_cache_path(dat_path):
    """
    Returns the cache file path for a DAT file.
    """

    dat_name = os.path.basename(dat_path)
    return os.path.join(get_cache_dir(), f"{dat_name}.index.json")


def build_dat_index(dat_path):
    """
    Builds a rom_name -> rom filenames index by streaming the DAT file once.
    This avoids loading the entire XML tree into memory while indexing.
    """

    entries = {}

    try:
        context = ET.iterparse(dat_path, events=("end",))
        for _, elem in context:
            if elem.tag not in ("game", "machine"):
                continue

            rom_name = elem.get("name", "").lower()
            if rom_name:
                roms = {
                    rom.get("name", "").lower()
                    for rom in elem.iter("rom")
                    if rom.get("name")
                }
                entries[rom_name] = sorted(roms)

            elem.clear()
    except ET.ParseError as e:
        print(f"  WARNING: Could not parse {dat_path}: {e}", file=sys.stderr)
        return None

    return entries


def load_or_build_dat_index(dat_path):
    """
    Loads a cached DAT index or rebuilds it if the DAT has changed.
    """

    cache_path = get_cache_path(dat_path)
    dat_stat = os.stat(dat_path)

    try:
        with open(cache_path, "r", encoding="utf-8") as fh:
            payload = json.load(fh)
        if (
            payload.get("source_size") == dat_stat.st_size
            and payload.get("source_mtime_ns") == dat_stat.st_mtime_ns
        ):
            return payload.get("entries", {})
    except (FileNotFoundError, json.JSONDecodeError, OSError):
        pass

    entries = build_dat_index(dat_path)
    if entries is None:
        return None

    payload = {
        "source_size": dat_stat.st_size,
        "source_mtime_ns": dat_stat.st_mtime_ns,
        "entries": entries,
    }
    tmp_path = f"{cache_path}.tmp"

    try:
        with open(tmp_path, "w", encoding="utf-8") as fh:
            json.dump(payload, fh, separators=(",", ":"))
        os.replace(tmp_path, cache_path)
    except OSError:
        # A cache write failure should not block lookups.
        try:
            os.unlink(tmp_path)
        except OSError:
            pass

    return entries


def load_dat(dat_path, rom_name):
    """
    Parses a MAME XML DAT file and returns the set of expected filenames
    for the given rom_name, or None if the game isn't listed in that DAT.
    """

    entries = load_or_build_dat_index(dat_path)
    if entries is None:
        return None

    dat_files = entries.get(rom_name)
    if dat_files is None:
        return None

    return set(dat_files)


def match_score(zip_files, dat_files):
    """
    Returns a float 0.0–1.0 representing how well the zip matches the DAT entry.
    1.0 = perfect match, 0.0 = no overlap.
    """

    if not dat_files:
        return 0.0
    overlap = zip_files & dat_files
    # Score: harmonic-style — penalise both missing and extra files
    precision = len(overlap) / len(zip_files) if zip_files else 0.0
    recall    = len(overlap) / len(dat_files)
    if precision + recall == 0:
        return 0.0
    return 2 * precision * recall / (precision + recall)


def main():
    # ── Argument validation ───────────────────────────────────────────────────
    if len(sys.argv) != 2:
        print(f"Usage: {sys.argv[0]} <rom.zip>")
        sys.exit(1)

    zip_path   = sys.argv[1]
    dat_folder = os.path.dirname(os.path.realpath(__file__))

    if not os.path.isfile(zip_path):
        die(f"ROM zip not found: {zip_path}")

    if not zipfile.is_zipfile(zip_path):
        die(f"Not a valid zip file: {zip_path}")

    # ── Load zip contents ─────────────────────────────────────────────────────
    rom_name  = get_rom_name(zip_path)
    zip_files = get_zip_filenames(zip_path)

    if not zip_files:
        die("The zip file is empty.")

    # ── Match against each DAT ────────────────────────────────────────────────
    best_core  = DEFAULT_CORE
    best_score = -1.0

    for core_def in CORES:
        dat_path = os.path.join(dat_folder, core_def["dat"])

        if not os.path.isfile(dat_path):
            # DAT not available locally, skip silently
            continue

        dat_files = load_dat(dat_path, rom_name)

        if dat_files is None:
            # Game not listed in this DAT
            continue

        score = match_score(zip_files, dat_files)

        if score > best_score:
            best_score = score
            best_core  = core_def["core"]

    # ── Output ────────────────────────────────────────────────────────────────
    print(best_core)


if __name__ == "__main__":
    main()
